{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Docker: Build image",
      "type": "shell",
      "command": "docker compose build",
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Compose: Up (build, detached)",
      "type": "shell",
      "command": "docker compose up -d --build",
      "problemMatcher": []
    },
    {
      "label": "Compose: Down",
      "type": "shell",
      "command": "docker compose down",
      "problemMatcher": []
    },
    {
      "label": "Backend: Tests",
      "type": "shell",
      "command": "python -m pytest -q",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Frontend: Tests",
      "type": "shell",
      "command": "npm test",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Frontend: Build",
      "type": "shell",
      "command": "npm ci && npm run build",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "ESP32: Compile",
      "type": "shell",
      "command": "pio run",
      "options": { "cwd": "${workspaceFolder}/firmware/esp32-wroom32-devkit-v1" },
      "problemMatcher": []
    },
    {
      "label": "ESP32: Upload",
      "type": "shell",
      "command": "pio run --target upload",
      "options": { "cwd": "${workspaceFolder}/firmware/esp32-wroom32-devkit-v1" },
      "problemMatcher": []
    },
    {
      "label": "ESP32: Serial monitor",
      "type": "shell",
      "command": "pio device monitor",
      "options": { "cwd": "${workspaceFolder}/firmware/esp32-wroom32-devkit-v1" },
      "problemMatcher": []
    }
  ]
}
