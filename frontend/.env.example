# Frontend build/runtime configuration.
# In production the backend serves the built assets and hosts the API/WS on the
# same origin, so these are only needed for standalone dev against a remote backend.

# Base URL for REST calls. Empty => same origin (dev server proxies /api to :8080).
VITE_API_BASE=

# WebSocket path. Empty => derives from current origin (dev server proxies /ws).
VITE_WS_URL=
