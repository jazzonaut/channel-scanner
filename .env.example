# rtl-sdr-channel-detector — environment configuration
#
# Copy this file to `.env` (`cp .env.example .env`) and edit as needed.
# Every variable below has a sensible default. The defaults run the app in
# SIMULATION mode so it works with NO dongle attached.
#
# Frequencies are in Hz (integers). Times in ms unless noted.
#
# IMPORTANT — two kinds of settings:
#   * SCANNING settings (SDR backend/device, gain, ppm, scan range, step, dwell,
#     detection thresholds, FFT/display, IQ recording, retention) are only the
#     STARTING DEFAULTS. They are all editable live from the web UI (Settings
#     page) while the app runs — no restart, changes propagate to every browser.
#   * INFRASTRUCTURE settings (WEB_PORT, LOG_LEVEL, DATABASE_PATH,
#     RECORDING_PATH, CORS_ORIGINS) are deploy-time only and require a restart.

# --- SDR backend  (defaults; live-editable in UI Settings > Receiver) --------
# Which SDR source to use: sim | rtlsdr | soapy | rtl_power
#   sim       = synthetic spectrum, no hardware needed (default)
#   rtlsdr    = real RTL-SDR dongle via librtlsdr / pyrtlsdr
#   soapy     = real dongle via SoapySDR
#   rtl_power = sweep using the rtl_power CLI tool
SDR_BACKEND=sim

# Device index when multiple dongles are attached (0 = first).
SDR_DEVICE_INDEX=0

# Sample rate in Hz. 2.4 MS/s is a common, well-supported RTL-SDR rate.
SDR_SAMPLE_RATE=2400000

# Tuner gain: "auto" or a float in dB (e.g. 28.0).
SDR_GAIN=auto

# Frequency correction in parts-per-million for your dongle's crystal.
SDR_PPM=0

# --- Scan range  (defaults; live-editable in UI Settings > Band & sweep) -----
# Default window is ~867-870 MHz (EU 868 MHz ISM band region).
SCAN_START_HZ=867000000
SCAN_END_HZ=870000000

# Frequency step between dwell points in Hz. 0 = auto (derived from sample rate).
SCAN_STEP_HZ=0

# Dwell time per tuning step in milliseconds.
SCAN_DWELL_MS=120

# --- Detection  (defaults; live-editable in UI Settings > Detection) ---------
# Signal is "present" when power exceeds noise floor by this many dB.
DETECTION_THRESHOLD_DB=6.0

# EMA smoothing factor for the running noise-floor estimate (0..1, lower=smoother).
NOISE_FLOOR_ALPHA=0.05

# --- Storage  (paths = infra/restart; IQ + retention = live-editable in UI) --
# SQLite database path (inside the container; ./data is mounted to /data).
DATABASE_PATH=/data/db/channel_detector.sqlite3

# Directory for IQ recordings.
RECORDING_PATH=/data/recordings

# Enable short IQ recordings (off by default; see docs for storage implications).
ENABLE_IQ_RECORDING=false

# Hard cap on total IQ recording storage in gigabytes.
MAX_IQ_STORAGE_GB=2.0

# How many days of detections/events/recordings to retain before pruning.
RETENTION_DAYS=30

# --- Web server  (INFRASTRUCTURE — restart required) ------------------------
# Port the app serves on (host and container). UI at http://localhost:${WEB_PORT}
WEB_PORT=8080

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- Simulation  (default; live-editable in UI Settings > Receiver) ----------
# When true, or when no dongle is found, synthetic data is generated so the app
# is fully usable without hardware. Forced true when SDR_BACKEND=sim.
SIMULATION_MODE=true

# --- Signal processing / display  (defaults; live-editable in UI) -----------
# FFT size (power of two). Larger = finer frequency resolution, more CPU.
FFT_SIZE=2048

# Spectrum frames per second pushed to the browser (server-throttled).
SPECTRUM_FPS=10

# Number of spectrum bins sent to the browser (down-sampled from FFT_SIZE).
SPECTRUM_BINS=1024

# --- CORS  (INFRASTRUCTURE — restart required) ------------------------------
# Allowed origins for the API. "*" allows any origin (fine for local use).
CORS_ORIGINS=*
