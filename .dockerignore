# Keep the build context small and reproducible.
.git
.gitignore
**/node_modules
**/.venv
**/venv
**/__pycache__
**/*.pyc
**/dist
frontend/dist
**/.pio
.pio
data
!data/.gitkeep
docs
.vscode
.devcontainer
*.md
!README.md
.env
.env.*
!.env.example
**/.pytest_cache
**/.ruff_cache
**/.mypy_cache
**/coverage.xml
**/.DS_Store
