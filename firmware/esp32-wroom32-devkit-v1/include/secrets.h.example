// =============================================================================
//  secrets.h.example  —  TEMPLATE ONLY
//
//  Copy this file to  include/secrets.h  and fill in your real values:
//      cp include/secrets.h.example include/secrets.h
//
//  include/secrets.h is gitignored (see firmware .gitignore) — NEVER commit
//  real credentials. If you omit secrets.h entirely the firmware still builds
//  and falls back to the captive portal (AP mode) to configure Wi-Fi/server.
// =============================================================================
#pragma once

// ---- Wi-Fi (station mode) ----
#define WIFI_SSID  "your-wifi-ssid"
#define WIFI_PASS  "your-wifi-password"

// ---- rtl-sdr-channel-detector server ----
// Host/IP and port where the backend is reachable from the ESP32's network.
// The backend defaults to port 8080 (WEB_PORT) per the shared contract.
#define SERVER_HOST "192.168.1.50"
#define SERVER_PORT 8080
